{
  "expo": {
    "name": "شمامسة مارمرقس",
    "slug": "marmarkos-shamamsa",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "marmarkosshamamsa",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F0E4",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marmarkos.shamamsa",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": [
          "ar",
          "en"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.marmarkos.shamamsa",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7A1F2C"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#5C1721",
          "imageWidth": 240
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
